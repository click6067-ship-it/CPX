# 복사해서 .env로 만들고 값 채우기:  cp .env.example .env
GOOGLE_API_KEY=your-google-aistudio-key
GEMINI_MODEL=gemini-flash-lite-latest    # 최저가. 검증 후 상위모델로 교체 가능
GROQ_API_KEY=
UPSTAGE_API_KEY=
LANGSMITH_API_KEY=
OPENAI_API_KEY=

# --- 관찰·추적(observability) — 기본 OFF (민감데이터 SaaS 전송 주의) ---
# ⚠️ 켜면 프롬프트(사례·교과서 RAG)가 제3자 SaaS 로 전송 → CPX_TRACE_ACK=1 동의 필요.
#    비식별·합성 실행분에만 켤 것. LANGSMITH_TRACING 은 tracing.py 가 자동 관리(직접 X).
CPX_TRACE_ACK=                             # 1 로 설정 시에만 추적 활성(egress 동의)
LANGSMITH_PROJECT=cpx-ai
LANGFUSE_PUBLIC_KEY=                        # pk-lf-... (+ CPX_TRACE_ACK=1)
LANGFUSE_SECRET_KEY=                        # sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com   # US 리전=https://us.cloud.langfuse.com / 셀프호스트=해당 URL
