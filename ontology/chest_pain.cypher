// 흉통 온톨로지 — YAML→Cypher 자동생성. 정본=ontology/chest_pain.yaml. 손편집 금지.
MATCH (n) DETACH DELETE n;
MERGE (:ChiefComplaint {id:"chest_pain", label:"흉통"});
MERGE (:DiseasePrimary {id:"acute_coronary_syndrome", label:"급성 관상동맥증후군(ACS)"});
MERGE (:Symptom {id:"chest_pressure", label:"쥐어짜는 압박감"});
