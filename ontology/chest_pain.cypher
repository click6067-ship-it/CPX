MERGE (:Symptom {id:"radiation_to_left_arm_or_jaw", label:"좌측 팔·턱 방사"});
MERGE (:Symptom {id:"diaphoresis", label:"식은땀"});
MERGE (:Symptom {id:"dyspnea", label:"호흡곤란"});
MERGE (:RedFlag {id:"hypotension", label:"저혈압"});
MERGE (:RedFlag {id:"syncope", label:"실신"});
MERGE (:ChecklistItem {id:"ask_onset_duration", label:"발병·기간 묻기"});
