---
config:
  flowchart:
    curve: linear
---
graph TD;
	__start__([<p>__start__</p>]):::first
	generate(generate)
	review(review)
	revise(revise)
	__end__([<p>__end__</p>]):::last
	__start__ --> generate;
	generate --> review;
	review -. &nbsp;end&nbsp; .-> __end__;
	review -.-> revise;
	revise --> review;
	classDef default fill:#f2f0ff,line-height:1.2
	classDef first fill-opacity:0
	classDef last fill:#bfb6fc
